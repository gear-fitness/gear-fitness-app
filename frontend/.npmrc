# posthog-react-native has an optional peer dep on @react-navigation/native
# ">= 5.0.0", which our v8 alpha builds don't satisfy under strict semver
# (prereleases never match plain ranges). `npm install` only warns about
# optional peers, but the `npm ci` that EAS builds run hard-fails on it.
# Remove once react-navigation v8 ships stable.
legacy-peer-deps=true
